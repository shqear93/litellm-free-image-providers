# Copy to .env.github-secrets (gitignored) and fill in real values, then run:
#   mise run push-ci-secrets

# Fine-grained PAT (Contents: Read/write, Pull requests: Read/write, scoped
# to this repo only) -- lets release-please's release/push trigger the
# publish workflow, which the default GITHUB_TOKEN cannot do.
RELEASE_PLEASE_TOKEN=

# No PyPI token needed: publishing uses PyPI Trusted Publishing (OIDC), set
# up once at https://pypi.org/manage/project/litellm-free-image-providers/settings/publishing/
